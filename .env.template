# ScrumDo MCP Server — copy to .env and fill in values
# Never commit .env

# Required: API token from ScrumDo → Settings → API Tokens
SCRUMDO_TOKEN=

# Your organization slug (from your board URL: app.scrumdo.com/YOUR-ORG/...)
SCRUMDO_ORG=

# Default project slug
SCRUMDO_PROJECT=

# Optional: override the API base URL (leave blank for app.scrumdo.com)
# SCRUMDO_BASE_URL=https://app.scrumdo.com
