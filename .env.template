# ScrumDo MCP Server — copy to .env and fill in values
# Never commit .env

# Required: API token from ScrumDo → Settings → API Tokens
SCRUMDO_TOKEN=

# Your organization slug (from your board URL: app.spryng.io/YOUR-ORG/...)
SCRUMDO_ORG=

# Default project slug
SCRUMDO_PROJECT=

# Optional: override the API base URL (leave blank for app.spryng.io)
# SCRUMDO_BASE_URL=https://app.spryng.io

# Optional: AI Agent run attribution. When this MCP drives a specific
# AgentRun, set this to that run's numeric id. Every outbound write then
# carries the `X-Spryng-Agent-Run` header so the run's audit trail captures
# the writes (change_source='agent_run'). The token in SCRUMDO_TOKEN must be
# the agent's own token, and the run must belong to that agent.
# SCRUMDO_AGENT_RUN_ID=

# Optional: governed-loop attribution. When this MCP runs inside a loop, set
# this to the loop id. Writes carry the `X-Spryng-Loop` header and the
# loop-scoped tools default their loop_id to it.
# SPRYNG_LOOP_ID=
